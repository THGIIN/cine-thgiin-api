# Copie para .env e ajuste conforme o ambiente.
# cp .env.example .env

# development | production | test
NODE_ENV=development

# Porta HTTP (Nest)
PORT=3000

# PostgreSQL — use o mesmo host/porta do docker-compose ou sua instalação local
# Exemplo com Postgres do compose (serviço "postgres", DB cinearquivo):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cinearquivo?schema=public

# CORS: origens permitidas separadas por vírgula (ex.: http://localhost:5173). Vazio = reflete qualquer origem (apenas dev).
# CORS_ORIGIN=http://localhost:3000
